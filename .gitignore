# This .gitignore is appropriate for repositories deployed to Codeberg Pages and using
# a Gemfile as specified at https://codeberg.org/github/pages-gem#conventional

# Basic Jekyll gitignores (synchronize to Jekyll.gitignore)
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Additional Ruby/bundler ignore for when you run: bundle install
/vendor

# Specific ignore for Codeberg Pages
# Codeberg Pages will always use its own deployed version of pages-gem 
# This means Codeberg Pages will NOT use your Gemfile.lock and therefore it is
# counterproductive to check this file into the repository.
# Details at https://codeberg.org/github/pages-gem/issues/768
Gemfile.lock
